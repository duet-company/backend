{
  "dashboard": {
    "id": null,
    "title": "AI Data Labs - Platform Overview",
    "tags": ["ai-datalabs", "platform"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 0,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "API Requests per Second",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(ai_datalabs_api_requests_total[1m])) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth"
            }
          }
        }
      },
      {
        "id": 2,
        "title": "API Latency (P95)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(ai_datalabs_api_latency_seconds_bucket[1m])) by (le))",
            "legendFormat": "P95",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Seconds"},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "title": "API Error Rate",
        "type": "stat",
        "gridPos": {"x": 0, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(ai_datalabs_api_requests_total{status=\"error\"}[5m]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 0.1}
              ]
            },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 4,
        "title": "Active API Requests",
        "type": "stat",
        "gridPos": {"x": 6, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(ai_datalabs_api_active_requests)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 5,
        "title": "Agent Executions per Second",
        "type": "graph",
        "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(ai_datalabs_agent_executions_total[1m])) by (agent_name, status)",
            "legendFormat": "{{agent_name}} - {{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "title": "Agent Queue Sizes",
        "type": "graph",
        "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "ai_datalabs_agent_queue_size",
            "legendFormat": "{{agent_name}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "title": "LLM API Requests",
        "type": "graph",
        "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(ai_datalabs_llm_requests_total[1m])) by (provider, model)",
            "legendFormat": "{{provider}}/{{model}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "title": "LLM Token Usage",
        "type": "graph",
        "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(ai_datalabs_llm_tokens_total[1m])) by (provider, model, type)",
            "legendFormat": "{{provider}}/{{model}} - {{type}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 9,
        "title": "Database Query Latency",
        "type": "graph",
        "gridPos": {"x": 0, "y": 28, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(ai_datalabs_db_query_latency_seconds_bucket[1m])) by (le, db_type))",
            "legendFormat": "{{db_type}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Seconds"},
          {"format": "short"}
        ]
      },
      {
        "id": 10,
        "title": "Database Connections",
        "type": "graph",
        "gridPos": {"x": 12, "y": 28, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "ai_datalabs_db_connections_active",
            "legendFormat": "{{db_type}} active",
            "refId": "A"
          },
          {
            "expr": "ai_datalabs_db_connection_pool_size",
            "legendFormat": "{{db_type}} pool",
            "refId": "B"
          }
        ]
      },
      {
        "id": 11,
        "title": "Query Performance",
        "type": "graph",
        "gridPos": {"x": 0, "y": 36, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(ai_datalabs_query_latency_seconds_bucket[1m])) by (le))",
            "legendFormat": "P95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(ai_datalabs_query_latency_seconds_bucket[1m])) by (le))",
            "legendFormat": "P50",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Seconds"},
          {"format": "short"}
        ]
      },
      {
        "id": 12,
        "title": "System Resources",
        "type": "graph",
        "gridPos": {"x": 12, "y": 36, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "ai_datalabs_system_cpu_usage_percent",
            "legendFormat": "CPU %",
            "refId": "A"
          },
          {
            "expr": "ai_datalabs_system_memory_usage_bytes / 1024 / 1024 / 1024",
            "legendFormat": "Memory GB",
            "refId": "B"
          }
        ]
      },
      {
        "id": 13,
        "title": "Error Rate by Component",
        "type": "graph",
        "gridPos": {"x": 0, "y": 44, "w": 24, "h": 8},
        "targets": [
          {
            "expr": "sum(rate(ai_datalabs_errors_total[5m])) by (component, severity)",
            "legendFormat": "{{component}} - {{severity}}",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
